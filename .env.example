# 이 파일을 .env 로 복사한 뒤 실제 키를 채우세요.
#   Windows: copy .env.example .env
#   macOS:   cp .env.example .env
# .env 는 커밋되지 않습니다 (.gitignore 처리됨)

OPENAI_API_KEY=sk-여기에붙여넣기

# ---- 모델 설정 ----
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ---- Abstention: 이 값 미만이면 답변 거부 ----
# 7/22 실측 기반 (더미 15문서). 실제 문서 투입 후 재보정 필요.
CONFIDENCE_THRESHOLD=0.42

# ---- 검색 융합 (retriever.py) ----
FUSION=score
W_DENSE=1.0
W_BM25=1.0

# ---- 선배 라운지 의미 매칭 (local.py) ----
# 거부 직전 구제 단계에서 이 코사인 유사도 이상이면 가장 가까운 생활 팁으로
# 답합니다. 낮추면 리콜↑(무관 질문에도 팁), 높이면 정밀도↑(표현 조금만 달라도 놓침).
# 비자·이민 인접 질문이 생활 팁으로 오매칭되지 않게 보수적으로 설정(0.50).
# semantic 구제는 campus-life·culture·food 카테고리에만 적용됩니다.
LOCAL_SEM_THRESHOLD=0.50